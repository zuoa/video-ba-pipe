# ============================================
# Video BA Pipe 配置文件示例
# 复制此文件为 .env 并根据需要修改配置
# ============================================

# ============ 数据库配置 ============
# 本地直接运行默认走 SQLite；Docker/盒子部署默认走 PostgreSQL。
# 如需本地也切 PostgreSQL，请显式设置 DB_BACKEND=postgres。
# DB_BACKEND=postgres

# 应用数据库连接（PostgreSQL）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=video_ba_pipe
DB_USER=video_ba_pipe
DB_PASSWORD=video_ba_pipe
DB_SSLMODE=prefer

# SQLite 路径（仅 DB_BACKEND=sqlite 时使用）
DB_PATH=./app/data/db/ba.db

# Docker Compose 中 PostgreSQL 服务的初始化账号
# 默认建议与应用连接参数保持一致
POSTGRES_DB=video_ba_pipe
POSTGRES_USER=video_ba_pipe
POSTGRES_PASSWORD=video_ba_pipe

# ============ 存储路径配置 ============
# 预警图片保存路径
FRAME_SAVE_PATH=./app/data/frames

# 预警视频保存路径
VIDEO_SAVE_PATH=./app/data/videos

# 上传视频源文件保存路径
VIDEO_SOURCE_PATH=./app/data/video_sources

# 模型文件保存路径
MODEL_SAVE_PATH=./app/data/models

# 用户脚本保存路径
USER_SCRIPTS_ROOT=./app/data/user_scripts

# 快照保存路径
SNAPSHOT_PATH=./app/data/snapshots

# 日志保存路径
LOG_SAVE_PATH=./app/data/logs

# ============ 快照配置 ============
# 是否启用定时快照功能
SNAPSHOT_ENABLED=true

# 快照间隔（秒）
SNAPSHOT_INTERVAL=60

# ============ 解码器配置 ============
# 极速解码模式（丢弃中间帧，只取最新帧）
IS_EXTREME_DECODE_MODE=false

# 默认视频解码器类型
# 通用环境建议 ffmpeg_sw；RK3588 + rkmpp ffmpeg 建议 rk_mpp
VIDEO_DECODER_TYPE=ffmpeg_sw

# ffmpeg 软件解码线程数
# 多路并发时建议 1-2；数值越大，单路解码更快，但更容易把 CPU 打满
FFMPEG_SW_DECODER_THREADS=1

# 解码输出队列大小（原始 RGB 帧）
# 多路并发建议 3-5；数值越大，内存占用越高
DECODER_OUTPUT_QUEUE_SIZE=5

# ============ 视频录制配置 ============
# 预警录制功能开关
RECORDING_ENABLED=true

# 录制预警前的时长（秒）
# 建议：10-60秒
# 注意：不能超过 RECORDING_BUFFER_DURATION
PRE_ALERT_DURATION=30

# 录制预警后的时长（秒）
# 建议：10-60秒
POST_ALERT_DURATION=30

# 录制视频的帧率（FPS）
# 建议：5-15fps
# 说明：帧率越高视频越流畅，但占用存储和CPU更多
# - 5fps：适合资源受限环境，视频略有卡顿
# - 10fps：推荐值，平衡流畅度和资源占用
# - 15fps：较流畅，适合高性能服务器
RECORDING_FPS=10

# 分析缓冲区目标帧率（FPS）
# 工作流实时分析只消费最新帧，建议远低于源视频FPS
ANALYSIS_TARGET_FPS=3

# 分析缓冲区时长（秒）
# 仅用于分析链路，建议保持很小（例如 3-5 秒）
ANALYSIS_BUFFER_SECONDS=5

# 录制缓冲区时长（秒）
# 需要覆盖 PRE_ALERT_DURATION + POST_ALERT_DURATION
# 内存占用 ≈ 帧大小(字节) × RECORDING_FPS × RECORDING_BUFFER_DURATION
RECORDING_BUFFER_DURATION=62

# 录制缓冲区 JPEG 质量（仅 recording buffer 使用）
RECORDING_JPEG_QUALITY=85

# 录制缓冲区单帧最大字节数
RECORDING_COMPRESSED_MAX_BYTES=524288

# ============ 告警抑制配置 ============
# 告警抑制时长（秒）
# 说明：同一任务的同一算法在此时间内不会重复触发告警
# 建议：30-120秒，防止频繁告警和重复录制
# 例如：设置为60秒，则告警触发后60秒内检测到相同类型目标也不会再次告警
ALERT_SUPPRESSION_DURATION=60

# ============ 检测结果调试日志 ============
# 是否将每次算法检测结果追加写入 logs/detection_results_YYYYMMDD.jsonl
# 默认关闭，排查 RKNN/x86 输出差异时再临时开启
DETECTION_JSONL_LOG_ENABLED=false

# ============ RabbitMQ配置 ============
# 是否启用RabbitMQ预警发布功能
RABBITMQ_ENABLED=false

# RabbitMQ服务器配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# 预警消息队列配置
RABBITMQ_ALERT_QUEUE=video_alerts
RABBITMQ_ALERT_EXCHANGE=video_alerts
RABBITMQ_ALERT_ROUTING_KEY=alert

# Topic模式配置（支持多消费者订阅）
# 可选值: topic（广播模式，一个消息多个消费者）, direct（点对点模式，一个消息一个消费者）
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_ALERT_TOPIC_PATTERN=video.alert.*

# RabbitMQ连接超时设置（秒）
RABBITMQ_CONNECTION_TIMEOUT=30

# ============ 性能参考 ============
# 
# 配置方案1（推荐 - 标准监控）:
# ANALYSIS_TARGET_FPS=3
# ANALYSIS_BUFFER_SECONDS=5
# RECORDING_FPS=10
# RECORDING_BUFFER_DURATION=62
# PRE_ALERT_DURATION=30
# POST_ALERT_DURATION=30
# 分析内存占用：~0.9GB (1920×1080, 3fps, 5s)
# 录制内存占用：~3.7GB (1920×1080, 10fps, 62s)
# 视频时长：60秒
# 文件大小：~20-40MB/视频
#
# 配置方案2（高质量）:
# ANALYSIS_TARGET_FPS=5
# ANALYSIS_BUFFER_SECONDS=5
# RECORDING_FPS=15
# RECORDING_BUFFER_DURATION=92
# PRE_ALERT_DURATION=45
# POST_ALERT_DURATION=45
# 录制内存占用：~8.2GB (1920×1080, 15fps, 92s)
# 视频时长：90秒
# 文件大小：~40-80MB/视频
#
# 配置方案3（资源受限）:
# ANALYSIS_TARGET_FPS=2
# ANALYSIS_BUFFER_SECONDS=3
# RECORDING_FPS=5
# RECORDING_BUFFER_DURATION=42
# PRE_ALERT_DURATION=20
# POST_ALERT_DURATION=20
# 录制内存占用：~1.3GB (1920×1080, 5fps, 42s)
# 视频时长：40秒
# 文件大小：~8-15MB/视频
